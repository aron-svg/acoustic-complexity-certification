{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run main.py (src)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "args": [
                "--input",
                "${workspaceFolder}/data/input",
                "--output",
                "${workspaceFolder}/data/output",
            ]
        }
    ]
}